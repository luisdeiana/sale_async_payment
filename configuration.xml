<?xml version="1.0"?>
<tryton>
    <data>
        <!-- Vista form de configuración Singleton -->
        <record model="ir.ui.view" id="async_payment_config_view_form">
            <field name="model">sale.async_payment.config</field>
            <field name="type">form</field>
            <field name="name">async_payment_config_form</field>
        </record>

        <!-- Vistas de la grilla de vencimiento por método -->
        <record model="ir.ui.view"
            id="async_payment_config_line_view_tree">
            <field name="model">sale.async_payment.config.line</field>
            <field name="type">tree</field>
            <field name="name">async_payment_config_line_tree</field>
        </record>
        <record model="ir.ui.view"
            id="async_payment_config_line_view_form">
            <field name="model">sale.async_payment.config.line</field>
            <field name="type">form</field>
            <field name="name">async_payment_config_line_form</field>
        </record>

        <!-- Acción para abrir configuración -->
        <record model="ir.action.act_window"
            id="act_async_payment_config">
            <field name="name">Async Payment Configuration</field>
            <field name="res_model">sale.async_payment.config</field>
        </record>
        <record model="ir.action.act_window.view"
            id="act_async_payment_config_view_form">
            <field name="sequence" eval="10"/>
            <field name="view" ref="async_payment_config_view_form"/>
            <field name="act_window" ref="act_async_payment_config"/>
        </record>

        <!-- Menú: Configuración → Cobros asíncronos -->
        <menuitem
            id="menu_async_payment_config"
            name="Async Payments"
            parent="account.menu_account_configuration"
            action="act_async_payment_config"
            icon="tryton-settings"
            sequence="100"/>

        <!-- Vistas del filtro por usuario -->
        <record model="ir.ui.view" id="user_filter_view_form">
            <field name="model">sale.async_payment.user_filter</field>
            <field name="type">form</field>
            <field name="name">user_filter_form</field>
        </record>
        <record model="ir.ui.view" id="user_filter_view_tree">
            <field name="model">sale.async_payment.user_filter</field>
            <field name="type">tree</field>
            <field name="name">user_filter_tree</field>
        </record>

        <!-- Vista heredada de res.user con tab "Cobros asíncronos" -->
        <record model="ir.ui.view" id="user_view_form_async">
            <field name="model">res.user</field>
            <field name="inherit" ref="res.user_view_form"/>
            <field name="name">user_form_async</field>
        </record>
    </data>
</tryton>
