<?xml version="1.0"?>
<tryton>
    <data>
        <!-- Vistas del modelo sale.async_payment -->
        <record model="ir.ui.view" id="async_payment_view_form">
            <field name="model">sale.async_payment</field>
            <field name="type">form</field>
            <field name="name">async_payment_form</field>
        </record>
        <record model="ir.ui.view" id="async_payment_view_tree">
            <field name="model">sale.async_payment</field>
            <field name="type">tree</field>
            <field name="name">async_payment_tree</field>
        </record>

        <!-- Main action: list of async payments -->
        <record model="ir.action.act_window" id="act_async_payment">
            <field name="name">Pending Payments</field>
            <field name="res_model">sale.async_payment</field>
        </record>
        <record model="ir.action.act_window.view"
            id="act_async_payment_view_tree">
            <field name="sequence" eval="10"/>
            <field name="view" ref="async_payment_view_tree"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>
        <record model="ir.action.act_window.view"
            id="act_async_payment_view_form">
            <field name="sequence" eval="20"/>
            <field name="view" ref="async_payment_view_form"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>

        <!-- Predefined filters in the list view -->
        <record model="ir.action.act_window.domain"
            id="act_async_payment_domain_pending">
            <field name="name">Pending</field>
            <field name="sequence" eval="10"/>
            <field name="domain"
                eval="[('state', '=', 'pending')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>
        <record model="ir.action.act_window.domain"
            id="act_async_payment_domain_suggested">
            <field name="name">Suggested</field>
            <field name="sequence" eval="20"/>
            <field name="domain"
                eval="[('state', '=', 'suggested')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>
        <record model="ir.action.act_window.domain"
            id="act_async_payment_domain_expired">
            <field name="name">Expired</field>
            <field name="sequence" eval="30"/>
            <field name="domain"
                eval="[('state', '=', 'expired')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>
        <record model="ir.action.act_window.domain"
            id="act_async_payment_domain_confirmed">
            <field name="name">Confirmed</field>
            <field name="sequence" eval="40"/>
            <field name="domain"
                eval="[('state', '=', 'confirmed')]" pyson="1"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>
        <record model="ir.action.act_window.domain"
            id="act_async_payment_domain_all">
            <field name="name">All</field>
            <field name="sequence" eval="50"/>
            <field name="domain"/>
            <field name="act_window" ref="act_async_payment"/>
        </record>

        <!-- Menu: Payments → Pending Payments -->
        <menuitem
            id="menu_async_payment"
            name="Pending Payments"
            parent="account_payment_qr.menu_cobros_qr"
            action="act_async_payment"
            icon="tryton-list"
            sequence="10"/>
    </data>
</tryton>
